{
  "name": "rubikey",
  "version": "0.1.1",
  "private": true,
  "description": "Smart cube driven Windows macro tool",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist-electron/main/index.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json && node scripts/sync-preload.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "dist:win": "npm run dist:portable",
    "dist:dir": "node scripts/run-electron-builder.mjs --dir --win --x64",
    "dist:portable": "node scripts/run-electron-builder.mjs --win portable --x64",
    "dist:setup": "node scripts/run-electron-builder.mjs --win nsis --x64"
  },
  "dependencies": {
    "@nut-tree/nut-js": "^4.2.0",
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.577.0",
    "lz-string": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.huizhilll.rubikey",
    "productName": "RubiKey",
    "asar": true,
    "asarUnpack": [
      "dist-electron/main/preload.cjs"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "assets/**",
      "package.json"
    ],
    "win": {
      "icon": "assets/favicon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
